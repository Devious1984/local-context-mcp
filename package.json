{
    "name": "local-context-mcp",
    "version": "0.1.6",
    "description": "Local semantic code search via MCP - works offline, indexes current directory",
    "type": "module",
    "bin": {
        "local-context-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Devious1984/local-context-mcp.git"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "chokidar": "^5.0.0",
        "ollama": "^0.5.0",
        "openai": "^4.0.0",
        "tree-sitter": "^0.21.0",
        "tree-sitter-c-sharp": "^0.21.0",
        "tree-sitter-cpp": "^0.21.0",
        "tree-sitter-go": "^0.21.0",
        "tree-sitter-java": "^0.21.0",
        "tree-sitter-javascript": "^0.21.0",
        "tree-sitter-python": "^0.21.0",
        "tree-sitter-rust": "^0.21.0",
        "tree-sitter-scala": "^0.23.0",
        "tree-sitter-typescript": "^0.21.0",
        "usearch": "^2.21.4",
        "voyageai": "^0.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.0.0",
        "vitest": "^2.0.0"
    }
}
